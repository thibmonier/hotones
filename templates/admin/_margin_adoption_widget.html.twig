{# US-112 T-112-03 — Margin adoption widget (% projets adoption marge temps réel) #}
{# 3 catégories Fresh / StaleWarning / StaleCritical + bar chart visualisation. #}

{% set s = margin_adoption.stats %}
{% set total = s.totalActive %}
{% set freshPct = total > 0 ? s.freshCount * 100 / total : 0 %}
{% set warningPct = total > 0 ? s.staleWarningCount * 100 / total : 0 %}
{% set criticalPct = total > 0 ? s.staleCriticalCount * 100 / total : 0 %}

<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">
                        🎯 Adoption marge temps réel
                        <small class="text-muted">% projets actifs avec snapshot &lt; 7 j</small>
                    </h5>
                    {% if margin_adoption.warningTriggered %}
                        <span class="badge bg-warning text-dark"
                              title="Adoption fresh ({{ s.freshPercent|number_format(1, ',', ' ') }} %) sous le seuil {{ margin_adoption.warningThresholdPercent|number_format(0, ',', ' ') }} %">
                            ⚠ Sous le seuil (&lt; {{ margin_adoption.warningThresholdPercent|number_format(0, ',', ' ') }} %)
                        </span>
                    {% endif %}
                </div>

                {% if total == 0 %}
                    <div class="alert alert-info mb-0">
                        Aucun projet actif. Le KPI sera disponible dès qu'un projet sera créé.
                    </div>
                {% else %}
                    <div class="text-center mb-3">
                        <div class="fs-1 fw-bold {{ margin_adoption.warningTriggered ? 'text-warning' : 'text-success' }}">
                            {{ s.freshPercent|number_format(1, ',', ' ') }} %
                        </div>
                        <small class="text-muted">
                            {{ s.freshCount }} projet{{ s.freshCount > 1 ? 's' : '' }} frais sur {{ total }} actif{{ total > 1 ? 's' : '' }}
                        </small>
                    </div>

                    {# Bar chart — 3 segments empilés horizontaux #}
                    <div class="progress mb-2" style="height: 24px;" role="progressbar" aria-label="Répartition adoption marge">
                        {% if s.freshCount > 0 %}
                            <div class="progress-bar bg-success"
                                 style="width: {{ freshPct }}%"
                                 title="Frais : {{ s.freshCount }} ({{ freshPct|number_format(1, ',', ' ') }} %)">
                                {{ s.freshCount }}
                            </div>
                        {% endif %}
                        {% if s.staleWarningCount > 0 %}
                            <div class="progress-bar bg-warning text-dark"
                                 style="width: {{ warningPct }}%"
                                 title="Tiède : {{ s.staleWarningCount }} ({{ warningPct|number_format(1, ',', ' ') }} %)">
                                {{ s.staleWarningCount }}
                            </div>
                        {% endif %}
                        {% if s.staleCriticalCount > 0 %}
                            <div class="progress-bar bg-danger"
                                 style="width: {{ criticalPct }}%"
                                 title="Stale : {{ s.staleCriticalCount }} ({{ criticalPct|number_format(1, ',', ' ') }} %)">
                                {{ s.staleCriticalCount }}
                            </div>
                        {% endif %}
                    </div>

                    <div class="d-flex justify-content-between small">
                        <span><span class="badge bg-success">●</span> Frais (&lt; 7 j) : <strong>{{ s.freshCount }}</strong></span>
                        <span><span class="badge bg-warning text-dark">●</span> Tiède (7-30 j) : <strong>{{ s.staleWarningCount }}</strong></span>
                        <span><span class="badge bg-danger">●</span> Stale (&gt; 30 j ou jamais) : <strong>{{ s.staleCriticalCount }}</strong></span>
                    </div>
                {% endif %}

                <p class="text-muted small mt-3 mb-0">
                    Indicateur trigger abandon ADR-0013 cas 2. Seuil warning : {{ margin_adoption.warningThresholdPercent|number_format(0, ',', ' ') }} %.
                </p>
            </div>
        </div>
    </div>
</div>
