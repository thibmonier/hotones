<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Domain\Order\Entity\OrderSection" table="order_sections">
        <id name="id" type="order_section_id" column="id">
            <generator strategy="NONE"/>
        </id>

        <field name="title" type="string" length="255" nullable="false"/>
        <field name="position" type="integer" nullable="false"/>
        <field name="createdAt" type="datetime_immutable" column="created_at" nullable="false"/>
        <field name="updatedAt" type="datetime_immutable" column="updated_at" nullable="true"/>

        <!-- Many-to-One relationship with Order -->
        <many-to-one field="order" target-entity="App\Domain\Order\Entity\Order" inversed-by="sections">
            <join-column name="order_id" referenced-column-name="id" nullable="false" on-delete="CASCADE"/>
        </many-to-one>

        <!-- One-to-Many relationship with OrderLine -->
        <one-to-many field="lines" target-entity="App\Domain\Order\Entity\OrderLine" mapped-by="section" orphan-removal="true">
            <cascade>
                <cascade-persist/>
                <cascade-remove/>
            </cascade>
            <order-by>
                <order-by-field name="position" direction="ASC"/>
            </order-by>
        </one-to-many>
    </entity>

</doctrine-mapping>
